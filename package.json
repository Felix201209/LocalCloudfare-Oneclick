    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
